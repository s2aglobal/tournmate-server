rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isNonEmptyString(field) {
      return field is string && field.size() > 0;
    }

    // ─── Players ────────────────────────────────────────
    match /players/{playerId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.firebaseUid == request.auth.uid
        && isNonEmptyString(request.resource.data.name)
        && isNonEmptyString(request.resource.data.email);

      allow update: if isAuthenticated()
        && resource.data.firebaseUid == request.auth.uid;

      allow delete: if false;
    }

    // ─── Tournaments ────────────────────────────────────
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid
        && isNonEmptyString(request.resource.data.title)
        && request.resource.data.title.size() >= 3
        && request.resource.data.title.size() <= 100
        && isNonEmptyString(request.resource.data.location)
        && request.resource.data.date is timestamp
        && request.resource.data.date > request.time;

      allow update: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;

      allow delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;
    }

    // ─── Registrations ──────────────────────────────────
    match /registrations/{registrationId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && isNonEmptyString(request.resource.data.tournamentId)
        && isNonEmptyString(request.resource.data.playerId);

      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ─── Matches ────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ─── Ratings ────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && isNonEmptyString(request.resource.data.playerId)
        && isNonEmptyString(request.resource.data.raterId)
        && request.resource.data.playerId != request.resource.data.raterId
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;

      allow update: if false;
      allow delete: if false;
    }

    // ─── Calorie Records ────────────────────────────────
    match /calorieRecords/{recordId} {
      allow read, write: if isAuthenticated();
    }

    // ─── Play Sessions ──────────────────────────────────
    match /playSessions/{sessionId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.hostId == request.auth.uid
        && isNonEmptyString(request.resource.data.venue)
        && request.resource.data.date is timestamp
        && request.resource.data.date > request.time;

      allow update: if isAuthenticated()
        && resource.data.hostId == request.auth.uid;

      allow delete: if isAuthenticated()
        && resource.data.hostId == request.auth.uid;
    }

    // ─── Notifications ──────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if false;
    }
  }
}
